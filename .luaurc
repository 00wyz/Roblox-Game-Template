{
  "languageMode": "strict",
  "lint": {
    "*": true,
    "DeprecatedApi": true,
    "UnknownGlobal": true,
    "DeprecatedGlobal": true,
    "GlobalUsedAsLocal": true,
    "LocalUnused": true,
    "FunctionUnused": true,
    "ImportUnused": true,
    "BuiltinGlobalWrite": true,
    "PlaceholderRead": true,
    "UnreachableCode": true,
    "MisleadingAndOr": true,
    "DuplicateLocal": true,
    "FormatString": true,
    "TableOperations": true,
    "UninitializedLocal": true,
    "LocalShadow": false,
    "SameLineStatement": false,
    "MultiLineStatement": false
  }
}
